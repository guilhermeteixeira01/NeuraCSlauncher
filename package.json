{
  "name": "neuracs-launcher",
  "version": "1.0.1",
  "description": "Launcher CS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "release": "electron-builder --publish always",
    "release:win": "electron-builder --win --publish always",
    "release:mac": "electron-builder --mac --publish always",
    "release:linux": "electron-builder --linux --publish always"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-reload": "^2.0.0-alpha.1"
  },
  "dependencies": {
    "@xhayper/discord-rpc": "^1.2.0",
    "electron-updater": "^6.3.0"
  },
  "build": {
    "appId": "com.neuracs.launcher",
    "productName": "neuracs Launcher",
    "files": [
      "main.js",
      "preload.js",
      "discord-rpc.js",
      "auto-update.js",
      "steam-detect.js",
      "game-watcher.js",
      "src/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/logo.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/logo.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/logo.png"
    },
    "publish": {
      "provider": "github",
      "owner": "guilhermeteixeira01",
      "repo": "NeuraCSlauncher",
      "releaseType": "release"
    }
  }
}